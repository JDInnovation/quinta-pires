# Firebase Configuration
# Get these values from your Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI import frontend configuration
# 'mock' uses frontend mock logic; 'worker' sends requests to Cloudflare Worker
VITE_AI_IMPORT_MODE=mock
VITE_AI_WORKER_URL=

# Internal area access (comma-separated emails)
VITE_INTERNAL_ADMIN_EMAILS=
